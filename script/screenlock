#!/bin/sh

HIBERNATE_TIMEOUT="$(echo "20*60" | bc)"
IMMEDIATE_TIMEOUT=2
HIBERNATE_CMD="loginctl hibernate"
SCREENLOCK_CMD=slock
IMMEDIATE_MODE=0
XIDLEHOOK_PID=

start_idlehook() {
    [ -x "$(command -v xidlehook)" ] || return 0
    xidlehook --detect-sleep --timer "$HIBERNATE_TIMEOUT" "$HIBERNATE_CMD" "" &
    XIDLEHOOK_PID=$!
    [ "$IMMEDIATE_MODE" -eq 1 ] && (sleep "$IMMEDIATE_TIMEOUT" && $HIBERNATE_CMD) &
}

stop_idlehook() {
    [ -n "$XIDLEHOOK_PID" ] || return 0
    kill "$XIDLEHOOK_PID" 2>/dev/null
}

while [ $# -gt 0 ]; do
    case $1 in
        -i|--immediate) IMMEDIATE_MODE=1 ;; # give some time to actually lock
    esac
    shift
done

if [ -x "$(command -v $SCREENLOCK_CMD)" ]; then
    start_idlehook
    $SCREENLOCK_CMD
    stop_idlehook
fi
